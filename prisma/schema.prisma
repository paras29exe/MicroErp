generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  SALES_MANAGER
  PURCHASE_MANAGER
  INVENTORY_MANAGER
  PRODUCTION_MANAGER
  ACCOUNTANT
}

model User {
  id           Int       @id @default(autoincrement())
  employeeId   String
  name         String
  email        String    @unique
  passwordHash String
  role         UserRole
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now()) @updatedAt

  @@map("users")
}
